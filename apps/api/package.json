{
  "name": "@wgp/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "worker": "tsx watch src/jobs/workers/unzip.worker.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker": "node dist/jobs/workers/unzip.worker.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:int": "vitest run --config vitest.int.config.ts",
    "migrate": "node-pg-migrate -m migrations",
    "migrate:down": "node-pg-migrate down -m migrations"
  },
  "dependencies": {
    "@wgp/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cos-nodejs-sdk-v5": "^2.14.8",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.2",
    "pg": "^8.14.1",
    "pg-boss": "^10.1.5",
    "unzipper": "^0.12.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.13",
    "@types/supertest": "^6.0.2",
    "@types/unzipper": "^0.10.11",
    "@types/uuid": "^10.0.0",
    "node-pg-migrate": "^7.9.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  }
}
